# PoultryGuard AI Environment Variables

# Database
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_DB=poultryguard_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=yoursecretkeyhere_change_this_for_production
ALGORITHM=HS256

# AI Keys (Required for Vet Assistant & SMS)
OPENAI_API_KEY=sk-xxxx-replace-with-your-key
TWILIO_ACCOUNT_SID=ACxxxx-replace-with-your-sid
TWILIO_AUTH_TOKEN=xxxx-replace-with-your-token
TWILIO_PHONE_NUMBER=+1234567890
